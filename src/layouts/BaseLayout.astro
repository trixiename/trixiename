---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  activePage?: 'home' | 'about' | 'case-studies' | 'contact';
}

const { title, description = "Professional portfolio - Management Accounting", activePage } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home', id: 'home' },
  { href: '/about', label: 'About', id: 'about' },
  { href: '/case-studies', label: 'Projects', id: 'case-studies' },
  { href: '/contact', label: 'Contact', id: 'contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans antialiased">
    <!-- Navigation -->
    <header class="bg-white/80 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="text-lg font-semibold text-slate-900 hover:text-blue-700 transition-colors">
          <span class="text-blue-600">MA</span> Portfolio
        </a>
        <div class="hidden sm:flex items-center gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`
                px-4 py-2 text-sm font-medium rounded-lg transition-colors
                ${activePage === link.id
                  ? 'bg-blue-50 text-blue-700'
                  : 'text-slate-600 hover:text-slate-900 hover:bg-slate-100'
                }
              `}
            >
              {link.label}
            </a>
          ))}
        </div>
        <!-- Mobile nav -->
        <div class="sm:hidden flex gap-2">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`
                px-3 py-1.5 text-xs font-medium rounded-lg transition-colors
                ${activePage === link.id
                  ? 'bg-blue-50 text-blue-700'
                  : 'text-slate-500 hover:text-slate-900'
                }
              `}
            >
              {link.label}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="text-sm text-slate-500">
            <p>&copy; 2026 Trixie Anne B. Name — Management Accounting Portfolio</p>
          </div>
          <div class="flex items-center gap-4 text-sm text-slate-400">
            <a href="mailto:your.email@example.com" class="hover:text-blue-600 transition-colors">Email</a>
            <a href="https://linkedin.com/in/yourprofile" target="_blank" class="hover:text-blue-600 transition-colors">LinkedIn</a>
            <a href="/contact" class="hover:text-blue-600 transition-colors">Contact</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
