---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  activePage?: 'home' | 'about' | 'case-studies' | 'contact';
}

const { title, description = "Professional portfolio - Management Accounting", activePage } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home', id: 'home' },
  { href: '/about', label: 'About', id: 'about' },
  { href: '/case-studies', label: 'Projects', id: 'case-studies' },
  { href: '/contact', label: 'Contact', id: 'contact' },
];
---

<script>
  // Mobile hamburger toggle
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('nav-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    }
  });
</script>
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans antialiased">
    <!-- Navigation -->
    <header class="bg-white/80 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="text-lg font-semibold text-slate-900 hover:text-blue-700 transition-colors">
          <span class="text-blue-600">MA</span> Portfolio
        </a>
        <!-- Desktop nav -->
        <div class="hidden sm:flex items-center gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`
                px-4 py-2 text-sm font-medium rounded-lg transition-colors
                ${activePage === link.id
                  ? 'bg-blue-50 text-blue-700'
                  : 'text-slate-600 hover:text-slate-900 hover:bg-slate-100'
                }
              `}
            >
              {link.label}
            </a>
          ))}
        </div>
        <!-- Mobile hamburger -->
        <button id="nav-toggle" class="sm:hidden p-2 rounded-lg text-slate-600 hover:bg-slate-100 transition-colors" aria-label="Toggle navigation">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </nav>
      <!-- Mobile dropdown menu -->
      <div id="nav-menu" class="hidden sm:hidden bg-white/95 backdrop-blur-md border-b border-slate-200">
        <div class="max-w-5xl mx-auto px-4 py-2 flex flex-col gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`
                px-4 py-3 text-base font-medium rounded-lg transition-colors
                ${activePage === link.id
                  ? 'bg-blue-50 text-blue-700'
                  : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'
                }
              `}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-10">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="text-xs sm:text-sm text-slate-500 text-center sm:text-left">
            <p>&copy; 2026 Trixie Anne B. Name — Management Accounting Portfolio</p>
          </div>
          <div class="flex items-center gap-2 sm:gap-4 text-sm text-slate-400">
            <a href="mailto:your.email@example.com" class="px-3 py-2 hover:text-blue-600 transition-colors">Email</a>
            <a href="https://linkedin.com/in/yourprofile" target="_blank" class="px-3 py-2 hover:text-blue-600 transition-colors">LinkedIn</a>
            <a href="/contact" class="px-3 py-2 hover:text-blue-600 transition-colors">Contact</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
