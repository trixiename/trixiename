---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  activePage?: 'home' | 'about' | 'case-studies' | 'contact';
}

const { title, description = "Professional portfolio - Trixie Anne B. Name", activePage } = Astro.props;

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base.slice(0, -1) : base;

const navLinks = [
  { href: basePath + '/', label: 'Home', id: 'home' },
  { href: basePath + '/about', label: 'Resume', id: 'about' },
  { href: basePath + '/case-studies', label: 'Projects', id: 'case-studies' },
  { href: basePath + '/contact', label: 'Contact', id: 'contact' },
];
---

<script>
  // Mobile hamburger toggle
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }

  // Scroll progress bar + back to top
  const progressBar = document.getElementById('progress-bar');
  const backToTop = document.getElementById('back-to-top');
  if (progressBar) {
    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? scrollTop / docHeight : 0;
      progressBar.style.transform = 'scaleX(' + progress + ')';

      if (backToTop) {
        if (scrollTop > 300) {
          backToTop.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
          backToTop.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
        } else {
          backToTop.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
          backToTop.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        }
      }
    });
  }
  if (backToTop) {
    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // Skeleton loader fade-out
  const skeleton = document.getElementById('skeleton');
  if (skeleton) {
    window.addEventListener('load', () => {
      setTimeout(() => {
        skeleton.style.opacity = '0';
        setTimeout(() => {
          skeleton.style.display = 'none';
        }, 500);
      }, 300);
    });
  }
</script>
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={basePath + '/favicon.svg'} />
    <title>{title}</title>
    <style>
      @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
      }
      .skeleton-shimmer {
        background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s ease-in-out infinite;
      }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans antialiased">
    <!-- Skeleton loader -->
    <div id="skeleton" class="fixed inset-0 z-[100] bg-white transition-opacity duration-500">
      <div class="animate-pulse">
        <!-- Skeleton header (matches actual header) -->
        <div class="h-16 border-b border-slate-100 flex items-center px-6 max-w-5xl mx-auto">
          <div class="w-40 h-4 skeleton-shimmer rounded"></div>
        </div>
        <!-- Skeleton title area (matches page headings on all pages) -->
        <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
          <div class="max-w-2xl">
            <div class="h-3 w-20 skeleton-shimmer rounded-full mb-4"></div>
            <div class="h-8 md:h-10 skeleton-shimmer rounded w-3/5 mb-3"></div>
            <div class="h-4 skeleton-shimmer rounded w-4/5 max-w-lg"></div>
          </div>
        </div>
        <!-- Skeleton content cards (generic grid that works for any page) -->
        <div class="border-y border-slate-100">
          <div class="max-w-5xl mx-auto px-6 py-10">
            <div class="grid md:grid-cols-2 gap-6">
              <div class="h-44 skeleton-shimmer rounded-xl"></div>
              <div class="h-44 skeleton-shimmer rounded-xl"></div>
            </div>
            <div class="grid md:grid-cols-3 gap-6 mt-6">
              <div class="h-32 skeleton-shimmer rounded-xl"></div>
              <div class="h-32 skeleton-shimmer rounded-xl"></div>
              <div class="h-32 skeleton-shimmer rounded-xl"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll progress bar -->
    <div id="progress-bar" class="fixed top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-blue-500 via-indigo-500 to-blue-600 z-[60] origin-left" style="transform: scaleX(0);"></div>
    <!-- Navigation -->
    <header class="bg-white/85 backdrop-blur-lg border-b border-slate-200/70 sticky top-0 z-50 shadow-[0_1px_4px_rgba(0,0,0,0.04)]">
      <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href={basePath + '/'} class="text-base md:text-lg font-semibold text-slate-900 hover:text-blue-700 transition-colors">
          Trixie Anne B. Name
        </a>
        <!-- Desktop nav -->
        <div class="hidden sm:flex items-center gap-0.5">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`
                px-3 lg:px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 relative
                ${activePage === link.id
                  ? 'text-blue-700 bg-blue-50/60'
                  : 'text-slate-600 hover:text-slate-900 hover:bg-slate-100'
                }
              `}
            >
              {link.label}
              {activePage === link.id && <span class="absolute bottom-0 left-2 right-2 h-0.5 bg-blue-600 rounded-full"></span>}
            </a>
          ))}
        </div>
        <!-- Mobile hamburger -->
        <button id="nav-toggle" class="sm:hidden p-2.5 rounded-xl text-slate-500 hover:text-slate-700 hover:bg-slate-100 transition-all" aria-label="Toggle navigation">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </nav>
      <!-- Mobile dropdown menu -->
      <div id="nav-menu" class="hidden sm:hidden bg-white/95 backdrop-blur-lg border-b border-slate-200/70 shadow-inner">
        <div class="max-w-5xl mx-auto px-5 py-3 flex flex-col gap-1.5">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`
                px-4 py-3 text-base font-medium rounded-xl transition-all duration-200
                ${activePage === link.id
                  ? 'bg-blue-50/80 text-blue-700 font-semibold shadow-sm border border-blue-100/50'
                  : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50 active:bg-slate-100'
                }
              `}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-10">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="text-xs sm:text-sm text-slate-500 text-center sm:text-left">
            <p>&copy; 2026 Trixie Anne B. Name — Management Accounting Portfolio</p>
          </div>
          <div class="flex items-center gap-2 sm:gap-4 text-sm text-slate-400">
            <a href="mailto:trixienameh@ggmail.com" class="px-3 py-2 hover:text-blue-600 transition-colors">Email</a>
            <a href="https://linkedin.com/in/trixiename" target="_blank" class="px-3 py-2 hover:text-blue-600 transition-colors">LinkedIn</a>
            <a href={basePath + '/contact'} class="px-3 py-2 hover:text-blue-600 transition-colors">Contact</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Back to top -->
    <button id="back-to-top" class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-full bg-white border border-slate-200/70 shadow-lg flex items-center justify-center text-slate-400 hover:text-blue-600 hover:border-blue-200 hover:shadow-xl transition-all duration-300 opacity-0 translate-y-4 pointer-events-none" aria-label="Back to top">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>
    </button>
  </body>
</html>
