---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base.slice(0, -1) : base;
const imgPath = base.endsWith('/') ? base + 'bk.jpg' : base + '/bk.jpg';
const profilePath = base.endsWith('/') ? base + 'profile.jpg' : base + '/profile.jpg';
---

<BaseLayout title="Resume - Trixie Anne B. Name" activePage="about">
  <!-- Paper-like resume container -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-16">
    <div class="bg-white shadow-sm sm:shadow-lg sm:border sm:border-slate-200 rounded-none sm:rounded-xl overflow-hidden">

      <!-- ===== RESUME HEADER ===== -->
      <div class="px-6 sm:px-10 lg:px-14 pt-8 sm:pt-12 pb-6 sm:pb-8 border-b border-slate-200">
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-5 sm:gap-8">
          <!-- Photo -->
          <div class="shrink-0">
            <img src={profilePath} alt="Trixie Anne B. Name" class="w-20 h-20 sm:w-28 sm:h-28 rounded-full object-cover ring-4 ring-slate-100" />
          </div>
          <div class="text-center sm:text-left flex-1">
            <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-slate-900 tracking-tight">Trixie Anne B. Name</h1>
            <p class="text-sm sm:text-base text-blue-700 font-medium mt-1">BS in Management Accounting Graduate</p>
            <p class="text-sm sm:text-base text-blue-700 font-medium">Certified Bookkeeper (PICAT)</p>
            <!-- Contact strip -->
            <div class="flex flex-wrap justify-center sm:justify-start gap-x-4 gap-y-1 mt-3 text-xs sm:text-sm text-slate-500">
              <span class="whitespace-nowrap">trixienameh@ggmail.com</span>
              <span class="hidden sm:inline text-slate-300">|</span>
              <span class="whitespace-nowrap">+63 9480586754</span>
              <span class="hidden sm:inline text-slate-300">|</span>
              <span class="whitespace-nowrap">linkedin.com/in/yourprofile</span>
              <span class="hidden sm:inline text-slate-300">|</span>
              <span class="whitespace-nowrap">[City, Country]</span>
            </div>
          </div>
        </div>
        <!-- Professional Summary -->
        <div class="mt-5 sm:mt-6 pt-4 sm:pt-5 border-t border-slate-100">
          <h2 class="text-xs font-bold text-slate-400 uppercase tracking-[0.15em] mb-2">Professional Summary</h2>
          <p class="text-sm sm:text-base text-slate-700 leading-relaxed">
            Certified Bookkeeper and recent Management Accounting graduate from Batangas State University (TNEU).
            Consistently recognized on the Dean's List throughout the program. Internship experience in
            finance operations and audit, with hands-on exposure to accounts payable, bank reconciliation,
            financial reporting, budget variance analysis, and external audit procedures. Seeking an
            entry-level Management Accounting role to apply academic training and practical skills in
            cost analysis, budgeting, and financial planning.
          </p>
        </div>
      </div>

      <!-- ===== RESUME BODY ===== -->
      <div class="px-6 sm:px-10 lg:px-14 py-6 sm:py-8 space-y-7 sm:space-y-9">

        <!-- EDUCATION -->
        <section>
          <h2 class="text-sm font-bold text-slate-900 uppercase tracking-[0.12em] border-b border-slate-300 pb-1.5 mb-4">Education</h2>

          <div class="mb-4">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
              <div>
                <h3 class="text-sm font-bold text-slate-900">BS Management Accounting</h3>
                <p class="text-sm text-slate-600">Batangas State University (TNEU) — Arasof Nasugbu Campus</p>
              </div>
              <span class="text-xs text-slate-400 shrink-0 sm:text-right">2022 &ndash; 2026</span>
            </div>
            <p class="text-xs text-slate-500 mt-1 italic">Transferred from BS Accountancy (1st&ndash;2nd Year)</p>
            <ul class="mt-2 space-y-1">
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span><strong>Dean's List:</strong> 1st Sem, 1st Year (BS Accty); 1st Sem, 2nd Year (BS Accty); 1st Sem, 3rd Year (BS MA)</span>
              </li>
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span><strong>Relevant Coursework:</strong> Cost Accounting, Managerial Accounting, Financial Management, Taxation, Auditing, Business Analytics, Strategic Management</span>
              </li>
            </ul>
          </div>

          <div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
              <div>
                <h3 class="text-sm font-bold text-slate-900">Senior High School — ABM Strand</h3>
                <p class="text-sm text-slate-600">Calaca Senior High School</p>
              </div>
              <span class="text-xs text-slate-400 shrink-0 sm:text-right">2020 &ndash; 2022</span>
            </div>
            <ul class="mt-2 space-y-1">
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>With High Honors (2021&ndash;2022)</span>
              </li>
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>With Honors (2020&ndash;2021)</span>
              </li>
            </ul>
          </div>
        </section>

        <!-- CERTIFICATION -->
        <section>
          <h2 class="text-sm font-bold text-slate-900 uppercase tracking-[0.12em] border-b border-slate-300 pb-1.5 mb-4">Certification</h2>

          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
            <div>
              <h3 class="text-sm font-bold text-slate-900">Certified Bookkeeper</h3>
              <p class="text-sm text-slate-600">[Certifying Body] — Issued [Year]</p>
            </div>
          </div>
          <p class="text-xs sm:text-sm text-slate-600 mt-2 leading-relaxed">
            Certified in bookkeeping principles including double-entry accounting,
            bank reconciliation, payroll processing, financial statement preparation,
            and internal controls.
          </p>
          <a href={imgPath} target="_blank" class="inline-block mt-3 group">
            <img src={imgPath} alt="Certified Bookkeeper Certificate" class="w-full max-w-xs sm:max-w-sm rounded-lg border border-slate-200 shadow-sm group-hover:shadow-md transition-shadow" />
          </a>
        </section>

        <!-- INTERNSHIP EXPERIENCE -->
        <section>
          <h2 class="text-sm font-bold text-slate-900 uppercase tracking-[0.12em] border-b border-slate-300 pb-1.5 mb-4">Internship Experience</h2>

          <div class="mb-5">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
              <div>
                <h3 class="text-sm font-bold text-slate-900">Finance Intern</h3>
                <p class="text-sm text-slate-600 italic">[Company Name] — [Location]</p>
              </div>
              <span class="text-xs text-slate-400 shrink-0 sm:text-right">[Month Year] &ndash; [Month Year]</span>
            </div>
            <ul class="mt-2 space-y-1">
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>Accounts payable processing, bank reconciliation, and monthly financial report preparation</span>
              </li>
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>Supported annual budget planning and variance analysis for department heads</span>
              </li>
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>Maintained accurate financial records ensuring compliance with company policies</span>
              </li>
            </ul>
          </div>

          <div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
              <div>
                <h3 class="text-sm font-bold text-slate-900">Audit Intern</h3>
                <p class="text-sm text-slate-600 italic">[Company Name] — [Location]</p>
              </div>
              <span class="text-xs text-slate-400 shrink-0 sm:text-right">[Month Year] &ndash; [Month Year]</span>
            </div>
            <ul class="mt-2 space-y-1">
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>Participated in external audit engagements including substantive testing and control documentation</span>
              </li>
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>Prepared audit workpapers in accordance with Philippine Standards on Auditing</span>
              </li>
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>Collaborated with senior auditors to identify process improvements for client accounting systems</span>
              </li>
            </ul>
          </div>
        </section>

        <!-- SKILLS -->
        <section>
          <h2 class="text-sm font-bold text-slate-900 uppercase tracking-[0.12em] border-b border-slate-300 pb-1.5 mb-4">Skills &amp; Expertise</h2>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <h3 class="text-xs font-bold text-slate-500 uppercase tracking-[0.1em] mb-2">Accounting &amp; Finance</h3>
              <ul class="space-y-1">
                <li class="text-xs sm:text-sm text-slate-600 flex gap-2"><span class="text-blue-600 shrink-0">&bull;</span> Certified Bookkeeping (Full-Cycle)</li>
                <li class="text-xs sm:text-sm text-slate-600 flex gap-2"><span class="text-blue-600 shrink-0">&bull;</span> Cost Accounting &amp; Analysis</li>
                <li class="text-xs sm:text-sm text-slate-600 flex gap-2"><span class="text-blue-600 shrink-0">&bull;</span> Budgeting &amp; Forecasting</li>
                <li class="text-xs sm:text-sm text-slate-600 flex gap-2"><span class="text-blue-600 shrink-0">&bull;</span> Financial Statement Preparation</li>
                <li class="text-xs sm:text-sm text-slate-600 flex gap-2"><span class="text-blue-600 shrink-0">&bull;</span> Bank Reconciliation &amp; Payroll</li>
                <li class="text-xs sm:text-sm text-slate-600 flex gap-2"><span class="text-blue-600 shrink-0">&bull;</span> Variance Analysis</li>
              </ul>
            </div>
            <div>
              <h3 class="text-xs font-bold text-slate-500 uppercase tracking-[0.1em] mb-2">Tools &amp; Technology</h3>
              <ul class="space-y-1">
                <li class="text-xs sm:text-sm text-slate-600 flex gap-2"><span class="text-blue-600 shrink-0">&bull;</span> Microsoft Office Suite (Word, Excel, PowerPoint)</li>
                <li class="text-xs sm:text-sm text-slate-600 flex gap-2"><span class="text-blue-600 shrink-0">&bull;</span> BIR Forms &amp; Tax Compliance</li>
                <li class="text-xs sm:text-sm text-slate-600 flex gap-2"><span class="text-blue-600 shrink-0">&bull;</span> Google Workspace</li>
                <li class="text-xs sm:text-sm text-slate-600 flex gap-2"><span class="text-blue-600 shrink-0">&bull;</span> QuickBooks (Basic)</li>
                <li class="text-xs sm:text-sm text-slate-600 flex gap-2"><span class="text-blue-600 shrink-0">&bull;</span> Online Banking &amp; Payment Platforms</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- PROFESSIONAL GOALS -->
        <section>
          <h2 class="text-sm font-bold text-slate-900 uppercase tracking-[0.12em] border-b border-slate-300 pb-1.5 mb-4">Professional Goals</h2>
          <p class="text-xs sm:text-sm text-slate-700 leading-relaxed">
            Seeking an <strong>entry-level Management Accounting role</strong> where I can apply my
            academic training, certification, and internship experience. Particularly interested in
            cost analysis, budgeting, and financial planning roles where I can contribute to
            data-driven business decisions and grow as a finance professional.
          </p>
        </section>

      </div>

      <!-- ===== RESUME FOOTER ===== -->
      <div class="px-6 sm:px-10 lg:px-14 py-4 sm:py-5 border-t border-slate-200 bg-slate-50">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-slate-400">
          <span>&copy; 2026 Trixie Anne B. Name</span>
          <div class="flex items-center gap-3">
            <a href="mailto:trixienameh@ggmail.com" class="hover:text-blue-600 transition-colors">Email</a>
            <a href="https://linkedin.com/in/yourprofile" target="_blank" class="hover:text-blue-600 transition-colors">LinkedIn</a>
            <a href={basePath + '/contact'} class="hover:text-blue-600 transition-colors">Contact</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
