---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base.slice(0, -1) : base;
const imgPath = base.endsWith('/') ? base + 'bk.jpg' : base + '/bk.jpg';
const profilePath = base.endsWith('/') ? base + 'profile.jpg' : base + '/profile.jpg';
---

<BaseLayout title="Resume - Trixie Anne B. Name" activePage="about">
  <!-- Paper-like resume container -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-16">
    <div class="bg-white shadow-sm sm:shadow-lg sm:border sm:border-slate-200 rounded-none sm:rounded-xl overflow-hidden">

      <!-- ===== RESUME HEADER ===== -->
      <div class="px-6 sm:px-10 lg:px-14 pt-8 sm:pt-12 pb-6 sm:pb-8 border-b border-slate-200">
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-5 sm:gap-8">
          <!-- Photo -->
          <div class="shrink-0">
            <img src={profilePath} alt="Trixie Anne B. Name" draggable="false" class="w-20 h-20 sm:w-28 sm:h-28 rounded-full object-cover ring-4 ring-slate-100 select-none" style="-webkit-user-drag: none; user-select: none;" />
          </div>
          <div class="text-center sm:text-left flex-1">
            <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-slate-900 tracking-tight">Trixie Anne B. Name</h1>
            <p class="text-sm sm:text-base text-blue-700 font-medium mt-1">Management Accountancy Professional</p>
            <!-- Contact strip -->
            <div class="flex flex-wrap justify-center sm:justify-start gap-x-1.5 gap-y-1 mt-3 text-xs sm:text-sm text-slate-500">
              <span class="whitespace-nowrap">trixienameh@gmail.com</span>
              <span class="text-slate-300 mx-0.5 hidden sm:inline">&middot;</span>
              <span class="whitespace-nowrap">+63 9480586754</span>
              <span class="hidden sm:inline text-slate-300 mx-0.5">&middot;</span>
              <span class="whitespace-nowrap">Batangas, Philippines</span>
            </div>
          </div>
        </div>
        <!-- Professional Summary -->
        <div class="mt-5 sm:mt-6 pt-4 sm:pt-5 border-t border-slate-100">
          <h2 class="text-xs font-bold text-slate-400 uppercase tracking-[0.15em] mb-2">Professional Summary</h2>
          <p class="text-sm sm:text-base text-slate-700 leading-relaxed">
            Management Accountancy professional with a strong academic foundation in financial management,
            bookkeeping and analytical reporting. Eager to apply and contribute accounting knowledge
            in an internship role by integrating academic learning with hands-on experience to learn
            real-world experiences and grow professionally.
          </p>
        </div>
      </div>

      <!-- ===== RESUME BODY ===== -->
      <div class="px-6 sm:px-10 lg:px-14 py-6 sm:py-8 space-y-8 sm:space-y-10">

        <!-- EDUCATION -->
        <section>
          <h2 class="text-sm font-bold text-slate-900 uppercase tracking-[0.12em] border-b border-slate-300 pb-1.5 mb-4">Education &amp; Certification</h2>

          <div class="mb-4">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
              <div>
                <h3 class="text-sm font-bold text-slate-900">BS Management Accounting</h3>
                <p class="text-sm text-slate-600">Batangas State University (TNEU) &mdash; ARASOF Nasugbu Campus</p>
              </div>
              <span class="text-xs text-slate-400 shrink-0 sm:text-right">2022 &ndash; 2026</span>
            </div>
            <ul class="mt-2 space-y-1.5">
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span><strong>Dean's List:</strong> 1st Sem, 1st Year (BS Accty); 1st Sem, 2nd Year (BS Accty); 1st Sem, 3rd Year (BS MA); 2nd Sem, 4th Year (BS MA)</span>
              </li>
            </ul>
          </div>

          <div class="mb-4">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
              <div>
                <h3 class="text-sm font-bold text-slate-900">Certified Bookkeeper</h3>
                <p class="text-sm text-slate-600">PICAT (Philippine Institute of Certified Accounting Technologist)</p>
              </div>
              <span class="text-xs text-slate-400 shrink-0 sm:text-right">2025</span>
            </div>
            <a href={imgPath} target="_blank" draggable="false" class="inline-block mt-3 group">
              <img src={imgPath} alt="Certified Bookkeeper Certificate" draggable="false" class="w-full max-w-xs sm:max-w-sm rounded-lg border border-slate-200 shadow-sm group-hover:shadow-md transition-shadow select-none" style="-webkit-user-drag: none; user-select: none;" />
            </a>
          </div>

          <div class="mb-4">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
              <div>
                <h3 class="text-sm font-bold text-slate-900">HP LIFE Online Course</h3>
                <p class="text-sm text-slate-600">HP Foundation</p>
              </div>
              <span class="text-xs text-slate-400 shrink-0 sm:text-right">2022</span>
            </div>
            <p class="text-xs sm:text-sm text-slate-600 mt-1">Cash Flow, Profit and Loss</p>
          </div>

          <div class="mb-4">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
              <div>
                <h3 class="text-sm font-bold text-slate-900">Accountancy, Business &amp; Management (ABM)</h3>
                <p class="text-sm text-slate-600">Calaca Senior High School &mdash; Calaca City, Batangas</p>
              </div>
              <span class="text-xs text-slate-400 shrink-0 sm:text-right">2020 &ndash; 2022</span>
            </div>
            <ul class="mt-2 space-y-1.5">
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>With High Honors (2021&ndash;2022)</span>
              </li>
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>With Honors (2020&ndash;2021)</span>
              </li>
            </ul>
          </div>

          <div class="mb-4">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
              <div>
                <h3 class="text-sm font-bold text-slate-900">Junior High School</h3>
                <p class="text-sm text-slate-600">Dacanlao Gregorio Agoncillo National High School &mdash; Calaca City, Batangas</p>
              </div>
              <span class="text-xs text-slate-400 shrink-0 sm:text-right">2016 &ndash; 2020</span>
            </div>
            <ul class="mt-2 space-y-1.5">
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>Consistent With Honors (2017&ndash;2020)</span>
              </li>
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>Member, The Mathematics Association of the Philippines, Inc. (MTAP)</span>
              </li>
            </ul>
          </div>

          <div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
              <div>
                <h3 class="text-sm font-bold text-slate-900">Elementary</h3>
                <p class="text-sm text-slate-600">Calaca Central School &mdash; Calaca City, Batangas</p>
              </div>
              <span class="text-xs text-slate-400 shrink-0 sm:text-right">2010 &ndash; 2016</span>
            </div>
          </div>
        </section>

        <!-- INTERNSHIP EXPERIENCE -->
        <section>
          <h2 class="text-sm font-bold text-slate-900 uppercase tracking-[0.12em] border-b border-slate-300 pb-1.5 mb-4">Internship Experience</h2>

          <div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
              <div>
                <h3 class="text-sm font-bold text-slate-900">Human Resource Development Intern</h3>
                <p class="text-sm text-slate-600 italic">Batangas I Electric Cooperative, Inc. (BATELEC I)</p>
              </div>
              <span class="text-xs text-slate-400 shrink-0 sm:text-right">Aug 20 &ndash; Nov 11, 2025</span>
            </div>
            <ul class="mt-2 space-y-1.5">
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>Assisted in payroll operations, including encoding labor costing, checking employees&rsquo; daily reports, and distributing pay slips.</span>
              </li>
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>Organized and filed personnel documents while ensuring confidentiality of employee information.</span>
              </li>
              <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
                <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
                <span>Assisted in organizing training programs and employee engagement activities.</span>
              </li>
            </ul>
          </div>
        </section>

        <!-- SEMINARS AND PARTICIPATIONS -->
        <section>
          <h2 class="text-sm font-bold text-slate-900 uppercase tracking-[0.12em] border-b border-slate-300 pb-1.5 mb-4">Seminars &amp; Participations</h2>

          <ul class="space-y-2">
            <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
              <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
              <span>Pathways to Success: Navigating your Career in Management Accounting (Webinar) &mdash; November 2022</span>
            </li>
            <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
              <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
              <span>National Federation of Junior Philippine Institute of Accountants &mdash; Member 2023&ndash;2024</span>
            </li>
          </ul>
        </section>

        <!-- SKILLS -->
        <section>
          <h2 class="text-sm font-bold text-slate-900 uppercase tracking-[0.12em] border-b border-slate-300 pb-1.5 mb-4">Skills</h2>

          <ul class="space-y-2">
            <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
              <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
              <span>Proficient in using Microsoft Office (Word, Excel, PowerPoint), and Canva.</span>
            </li>
            <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
              <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
              <span>Ability to work effectively both independently and in a team environment.</span>
            </li>
            <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
              <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
              <span>Strong communication and interpersonal skills.</span>
            </li>
            <li class="text-xs sm:text-sm text-slate-600 flex gap-2">
              <span class="text-blue-600 shrink-0 mt-0.5">&bull;</span>
              <span>Excellent in time management.</span>
            </li>
          </ul>
        </section>

      </div>

      <!-- ===== RESUME FOOTER ===== -->
      <div class="px-6 sm:px-10 lg:px-14 py-4 sm:py-5 border-t border-slate-200 bg-slate-50">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-slate-400">
          <span>&copy; 2026 Trixie Anne B. Name</span>
          <div class="flex items-center gap-3">
            <a href="mailto:trixienameh@ggmail.com" class="hover:text-blue-600 transition-colors">Email</a>
            <a href={basePath + '/contact'} class="hover:text-blue-600 transition-colors">Contact</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
