---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact - Management Accounting Portfolio" activePage="contact">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    <span class="section-label">Contact</span>
    <h1 class="text-2xl md:text-4xl font-bold text-slate-900 mb-3 md:mb-4">Get In Touch</h1>
    <p class="text-slate-600 text-sm sm:text-base md:text-lg mb-8 md:mb-12 leading-relaxed">
      I'm actively seeking entry-level management accounting opportunities.
      Feel free to reach out — I'd love to hear from you!
    </p>

    <!-- Contact Info Cards -->
    <div class="grid md:grid-cols-2 gap-3 md:gap-4 mb-8 md:mb-12">
      <!-- Email -->
      <a href="mailto:trixienameh@ggmail.com" class="card flex items-center gap-3 md:gap-4 hover:border-blue-300 group">
        <div class="w-10 h-10 md:w-12 md:h-12 bg-blue-50 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-blue-100 transition-colors">
          <svg class="w-5 h-5 md:w-6 md:h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs md:text-sm text-slate-500">Email</p>
          <p class="text-sm md:text-base font-medium text-slate-900 truncate group-hover:text-blue-700 transition-colors">trixienameh@ggmail.com</p>
        </div>
      </a>

      <!-- Phone -->
      <a href="tel:+639480586754" class="card flex items-center gap-3 md:gap-4 hover:border-blue-300 group">
        <div class="w-10 h-10 md:w-12 md:h-12 bg-blue-50 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-blue-100 transition-colors">
          <svg class="w-5 h-5 md:w-6 md:h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs md:text-sm text-slate-500">Phone</p>
          <p class="text-sm md:text-base font-medium text-slate-900 group-hover:text-blue-700 transition-colors">+63 9480586754</p>
        </div>
      </a>

      <!-- LinkedIn -->
      <a href="https://linkedin.com/in/yourprofile" target="_blank" class="card flex items-center gap-3 md:gap-4 hover:border-blue-300 group">
        <div class="w-10 h-10 md:w-12 md:h-12 bg-blue-50 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-blue-100 transition-colors">
          <svg class="w-5 h-5 md:w-6 md:h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs md:text-sm text-slate-500">LinkedIn</p>
          <p class="text-sm md:text-base font-medium text-slate-900 truncate group-hover:text-blue-700 transition-colors">linkedin.com/in/yourprofile</p>
        </div>
      </a>

      <!-- Location -->
      <div class="card flex items-center gap-3 md:gap-4">
        <div class="w-10 h-10 md:w-12 md:h-12 bg-blue-50 rounded-xl flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 md:w-6 md:h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs md:text-sm text-slate-500">Location</p>
          <p class="text-sm md:text-base font-medium text-slate-900">Nasugbu, Batangas, Philippines</p>
        </div>
      </div>
    </div>

    <!-- Send a Message Section -->
    <div class="max-w-xl mx-auto">
      <h2 class="text-lg md:text-xl font-semibold text-slate-900 mb-4 md:mb-6">Send a Message</h2>

      <form
        action="mailto:trixienameh@ggmail.com"
        method="get"
        enctype="text/plain"
        class="space-y-4 md:space-y-5"
      >
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">Your Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Juan Dela Cruz"
              class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">Your Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="juan@example.com"
              class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow"
            />
          </div>
        </div>

        <div>
          <label for="subject" class="block text-sm font-medium text-slate-700 mb-1.5">Subject</label>
          <input
            type="text"
            id="subject"
            name="subject"
            placeholder="Job Opportunity / Collaboration"
            class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-slate-700 mb-1.5">Message</label>
          <textarea
            id="message"
            name="body"
            rows="5"
            required
            placeholder="Hi Trixie, I came across your portfolio and would love to connect..."
            class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow resize-y"
          ></textarea>
        </div>

        <div class="text-center">
          <button
            type="submit"
            class="inline-flex items-center gap-2 px-6 md:px-8 py-3 md:py-3.5 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition-colors shadow-md text-sm md:text-base w-full sm:w-auto justify-center"
          >
            <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            Send Message
          </button>
          <p class="text-xs text-slate-400 mt-3">This opens your email app with the form details pre-filled</p>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>
