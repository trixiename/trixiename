---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact - Trixie Anne B. Name" activePage="contact">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    <span class="section-label">Contact</span>
    <h1 class="text-2xl md:text-4xl font-bold text-slate-900 mb-3 md:mb-4">Get In Touch</h1>
    <p class="text-slate-600 text-sm sm:text-base md:text-lg mb-8 md:mb-12 leading-relaxed">
      I'm actively seeking entry-level management accounting opportunities.
      Feel free to reach out — I'd love to hear from you!
    </p>

    <!-- Contact Info Cards -->
    <div class="grid md:grid-cols-2 gap-4 md:gap-4 mb-8 md:mb-12">
      <!-- Email -->
      <a href="mailto:trixienameh@gmail.com" class="card flex items-center gap-3 md:gap-4 hover:border-blue-300 group">
        <div class="w-10 h-10 md:w-12 md:h-12 bg-blue-50 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-blue-100 transition-colors">
          <svg class="w-5 h-5 md:w-6 md:h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs md:text-sm text-slate-500">Email</p>
          <p class="text-sm md:text-base font-medium text-slate-900 truncate group-hover:text-blue-700 transition-colors">trixienameh@gmail.com</p>
        </div>
      </a>

      <!-- Phone -->
      <a href="tel:+639480586754" class="card flex items-center gap-3 md:gap-4 hover:border-blue-300 group">
        <div class="w-10 h-10 md:w-12 md:h-12 bg-blue-50 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-blue-100 transition-colors">
          <svg class="w-5 h-5 md:w-6 md:h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs md:text-sm text-slate-500">Phone</p>
          <p class="text-sm md:text-base font-medium text-slate-900 group-hover:text-blue-700 transition-colors">+63 9480586754</p>
        </div>
      </a>

      <!-- LinkedIn -->
      <a href="https://linkedin.com/in/trixiename" target="_blank" class="card flex items-center gap-3 md:gap-4 hover:border-blue-300 group">
        <div class="w-10 h-10 md:w-12 md:h-12 bg-blue-50 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-blue-100 transition-colors">
          <svg class="w-5 h-5 md:w-6 md:h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs md:text-sm text-slate-500">LinkedIn</p>
          <p class="text-sm md:text-base font-medium text-slate-900 truncate group-hover:text-blue-700 transition-colors">linkedin.com/in/trixiename</p>
        </div>
      </a>

      <!-- Location -->
      <div class="card flex items-center gap-3 md:gap-4">
        <div class="w-10 h-10 md:w-12 md:h-12 bg-blue-50 rounded-xl flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 md:w-6 md:h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs md:text-sm text-slate-500">Location</p>
          <p class="text-sm md:text-base font-medium text-slate-900">Nasugbu, Batangas, Philippines</p>
        </div>
      </div>
    </div>

    <!-- Contact Form Section -->
    <div class="max-w-xl mx-auto">
      <h2 class="text-lg md:text-xl font-semibold text-slate-900 mb-3 md:mb-4 text-center">Send a Message</h2>
      <p class="text-sm md:text-base text-slate-600 mb-6 md:mb-8 text-center leading-relaxed">
        Fill out the form below and I'll get back to you within 24 hours.
      </p>

      <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-5 md:space-y-6">
        <input type="hidden" name="access_key" value="db7b1ed2-ce1c-4c18-bcb8-864d0e0fafa6">
        <input type="hidden" name="subject" value="New message from your Portfolio">
        <input type="hidden" name="from_name" value="Portfolio Contact Form">

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">Name *</label>
            <input type="text" id="name" name="name" required
              placeholder="Your name"
              class="w-full px-4 py-3 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow">
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">Email *</label>
            <input type="email" id="email" name="email" required
              placeholder="your@email.com"
              class="w-full px-4 py-3 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow">
          </div>
        </div>

        <div>
          <label for="subject_line" class="block text-sm font-medium text-slate-700 mb-1.5">Subject</label>
          <input type="text" id="subject_line" name="subject_line"
            placeholder="Job Opportunity / Collaboration"
            class="w-full px-4 py-3 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow">
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-slate-700 mb-1.5">Message *</label>
          <textarea id="message" name="message" required rows="5"
            placeholder="Hi Trixie, I came across your portfolio and would love to connect..."
            class="w-full px-4 py-3 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow resize-y"></textarea>
        </div>

        <!-- Honeypot -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none;">

        <div class="text-center">
          <button type="submit" id="submit-btn"
            class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition-colors shadow-md text-sm md:text-base w-full sm:w-auto">
            <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            Send Message
          </button>
        </div>
      </form>

      <!-- Success message (hidden by default) -->
      <div id="form-success" class="hidden text-center py-8">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 mb-2">Message Sent!</h3>
        <p class="text-sm text-slate-600">Thank you for reaching out. I'll respond within 24 hours.</p>
      </div>

      <p class="text-xs text-slate-400 text-center mt-4">
        Or email me directly at <a href="mailto:trixienameh@gmail.com" class="text-blue-600 hover:underline">trixienameh@gmail.com</a>
      </p>
    </div>

    <script>
      const form = document.getElementById('contact-form');
      const success = document.getElementById('form-success');
      const submitBtn = document.getElementById('submit-btn');

      // Rate limiting: max 2 submissions per browser
      const STORAGE_KEY = 'portfolio_submit_count';
      const MAX_SUBMITS = 2;
      const RESET_HOURS = 24;

      function getSubmitCount() {
        try {
          const stored = localStorage.getItem(STORAGE_KEY);
          if (!stored) return 0;
          const data = JSON.parse(stored);
          const elapsed = Date.now() - data.timestamp;
          if (elapsed > RESET_HOURS * 60 * 60 * 1000) {
            localStorage.removeItem(STORAGE_KEY);
            return 0;
          }
          return data.count;
        } catch {
          return 0;
        }
      }

      function incrementSubmitCount() {
        try {
          const count = getSubmitCount();
          localStorage.setItem(STORAGE_KEY, JSON.stringify({
            count: count + 1,
            timestamp: Date.now()
          }));
        } catch {}
      }

      function getRemainingSubmits() {
        return Math.max(0, MAX_SUBMITS - getSubmitCount());
      }

      // Check rate limit on page load
      if (form && getSubmitCount() >= MAX_SUBMITS) {
        form.innerHTML = `
          <div class="text-center py-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-amber-100 rounded-full mb-4">
              <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">Submission Limit Reached</h3>
            <p class="text-sm text-slate-600">You've reached the maximum number of submissions. Please email me directly at <a href="mailto:trixienameh@gmail.com" class="text-blue-600 hover:underline">trixienameh@gmail.com</a></p>
          </div>
        `;
      }

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();

          // Check rate limit before submitting
          if (getSubmitCount() >= MAX_SUBMITS) {
            alert('You have reached the submission limit. Please email me directly at trixienameh@gmail.com');
            return;
          }

          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending...';

          const formData = new FormData(form);
          const data = Object.fromEntries(formData);

          try {
            const res = await fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data),
            });
            const json = await res.json();
            if (json.success) {
              incrementSubmitCount();
              form.classList.add('hidden');
              success.classList.remove('hidden');
            } else {
              alert('Something went wrong. Please email me directly at trixienameh@gmail.com');
              submitBtn.disabled = false;
              submitBtn.textContent = 'Send Message';
            }
          } catch {
            alert('Network error. Please email me directly at trixienameh@gmail.com');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Send Message';
          }
        });
      }
    </script>
  </div>
</BaseLayout>
