---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    slug: 'internship-batelec',
    category: 'Internship',
    title: 'Human Resource Development Intern — BATELEC I',
    description: 'Completed a university-required internship at Batangas I Electric Cooperative, Inc., gaining hands-on experience in payroll operations, personnel document management, and employee engagement activities within a real corporate HR setting.',
    tools: ['Microsoft Excel', 'Payroll System', 'Document Management'],
    outcomes: [
      'Assisted in encoding labor costing and checking employees\' daily reports for payroll processing',
      'Organized and filed personnel documents while ensuring confidentiality of employee information',
      'Supported training program logistics and employee engagement activities'
    ],
  },
  {
    slug: 'thesis-cost-analysis',
    category: 'Capstone Thesis',
    title: 'Cost Behavior Analysis in the Service Industry',
    description: 'Conducted an in-depth study of cost behavior patterns for a local service company using activity-based costing methodology. Analyzed fixed vs. variable costs, identified key cost drivers, and recommended strategies for cost optimization.',
    tools: ['Excel', 'ABC Framework', 'Financial Analysis'],
    outcomes: [
      'Identified 3 major cost drivers representing 70% of overhead',
      'Proposed restructuring strategy with estimated cost savings',
      'Presented to faculty panel and received positive feedback'
    ],
  },
  {
    slug: 'budget-competition',
    category: 'Case Competition',
    title: 'Inter-University Budgeting Simulation',
    description: 'Competed in a university-level budgeting simulation, developing a master budget, cash flow forecast, and strategic recommendations for a manufacturing company case study.',
    tools: ['Excel Financial Modeling', 'PowerPoint', 'Presentation'],
    outcomes: [
      'Developed a fully integrated master budget and cash flow forecast',
      'Demonstrated variance analysis and strategic decision-making',
      'Presented recommendations to a panel of judges'
    ],
  },
  {
    slug: 'dashboard-project',
    category: 'Academic Project',
    title: 'Management KPI Dashboard for a Retail Business',
    description: 'As part of a Management Accounting course, designed a performance measurement framework and built an interactive KPI dashboard tracking revenue, cost trends, inventory turnover, and profitability ratios.',
    tools: ['Excel', 'PowerPoint', 'Pivot Tables'],
    outcomes: [
      'Created 15+ interactive KPIs with trend analysis',
      'Simulated real-world monthly reporting process',
      'Demonstrated variance analysis and data-driven insights'
    ],
  },
  {
    slug: 'webinar-pathways',
    category: 'Seminar',
    title: 'Pathways to Success: Navigating your Career in Management Accounting',
    description: 'Attended an industry webinar focused on career pathways in Management Accounting, covering emerging trends, professional certifications, and skills needed for success in the field.',
    tools: ['Online Learning Platform'],
    outcomes: [
      'Gained insights into CMA and other professional certifications',
      'Learned about emerging trends in management accounting',
      'Networked with industry professionals and peers'
    ],
  },
  {
    slug: 'jpia-membership',
    category: 'Professional Organization',
    title: 'National Federation of Junior Philippine Institute of Accountants — Member',
    description: 'Active member of the student accounting organization, participating in seminars, workshops, and networking events designed to bridge academic learning with professional practice.',
    tools: ['Event Management', 'Team Collaboration'],
    outcomes: [
      'Attended professional development seminars and workshops',
      'Collaborated with fellow accounting students on organizational activities',
      'Built professional network within the accounting community'
    ],
  },
];
---

<BaseLayout title="Experience & Projects - Trixie Anne B. Name" activePage="case-studies">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    <span class="section-label">Portfolio</span>
    <h1 class="text-2xl md:text-4xl font-bold text-slate-900 mb-3 md:mb-4">Internships & Projects</h1>
    <p class="text-slate-600 text-sm sm:text-base md:text-lg mb-8 md:mb-12 max-w-2xl leading-relaxed">
      Internship experience, academic projects, and professional development activities
      demonstrating practical application of management accounting principles.
    </p>

    <div class="space-y-6">
      {projects.map((p) => (
        <article class="card">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide bg-blue-50 px-2.5 py-1 rounded-full">
              {p.category}
            </span>
          </div>
          <h2 class="text-base sm:text-lg md:text-xl font-semibold text-slate-900 mb-1.5 md:mb-3">{p.title}</h2>
          <p class="text-xs sm:text-sm md:text-base text-slate-600 mb-3 md:mb-5 leading-relaxed">{p.description}</p>

          <div class="mb-3 md:mb-4">
            <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5 md:mb-2">Tools Used</h4>
            <div class="flex flex-wrap gap-1.5 md:gap-2">
              {p.tools.map((t) => (
                <span class="text-xs bg-slate-100 text-slate-600 px-2 md:px-2.5 py-1 rounded-full font-medium">{t}</span>
              ))}
            </div>
          </div>

          <div>
            <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5 md:mb-2">Key Outcomes</h4>
            <ul class="space-y-1 md:space-y-1.5">
              {p.outcomes.map((o) => (
                <li class="text-xs sm:text-sm text-slate-600 flex items-start gap-2">
                  <span class="text-blue-600 font-bold shrink-0 mt-0.5">&rsaquo;</span>
                  {o}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
