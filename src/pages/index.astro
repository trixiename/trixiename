---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base.slice(0, -1) : base;
const imgPath = base.endsWith('/') ? base + 'bk.jpg' : base + '/bk.jpg';
const profilePath = base.endsWith('/') ? base + 'profile.jpg' : base + '/profile.jpg';
---

<BaseLayout title="Trixie Anne B. Name - Management Accounting Portfolio" activePage="home">
  <!-- Hero Section -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12 md:py-28">
    <div class="max-w-3xl">
      <div class="flex flex-col md:flex-row items-center md:items-start gap-6 md:gap-10 mb-6 md:mb-8">
        <div class="shrink-0">
          <div class="relative">
            <div class="absolute inset-0 rounded-full bg-blue-100 blur-xl opacity-60"></div>
            <img src={profilePath} alt="Trixie Anne B. Name" draggable="false" class="relative w-28 h-28 md:w-40 md:h-40 rounded-full object-cover ring-4 ring-white shadow-lg select-none" style="-webkit-user-drag: none; user-select: none;" />
          </div>
        </div>
        <div class="text-center md:text-left">
          <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 leading-tight">
            Trixie Anne B. Name
          </h1>
          <p class="text-sm sm:text-base md:text-lg text-blue-600 font-medium mt-2">BS in Management Accounting Graduate | Certified Bookkeeper</p>
        </div>
      </div>
      <p class="text-sm sm:text-base md:text-lg text-slate-600 leading-relaxed max-w-2xl mx-auto md:mx-0">
        Internship experience in finance operations and audit. Skilled in cost analysis,
        budgeting, financial reporting, and full-cycle bookkeeping.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 mt-6 md:mt-8 justify-center md:justify-start">
        <a href={basePath + '/about'} class="btn-primary">
          View My Resume
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href={basePath + '/contact'} class="btn-secondary">
          Contact Me
        </a>
      </div>
    </div>
  </section>

  <!-- Education + Certification Row -->
  <section class="bg-white py-10 md:py-16 border-y border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Education -->
        <div class="card">
          <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
            Education
          </h2>
          <h3 class="font-semibold text-slate-900">BS Management Accounting</h3>
          <p class="text-sm text-slate-600">Batangas State University (TNEU) — Arasof Nasugbu Campus</p>
          <p class="text-sm text-slate-400 mt-1">Previously BS Accountancy (1st-2nd Year)</p>
          <div class="mt-3 pt-3 border-t border-slate-100 text-sm text-slate-600">
            <p class="font-medium text-slate-700 mb-1">Dean's List:</p>
            <ul class="space-y-0.5">
              <li class="flex items-start gap-2">
                <span class="text-blue-600 mt-1 shrink-0">&#8226;</span>
                1st Sem, 1st Year — BS Accountancy
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue-600 mt-1 shrink-0">&#8226;</span>
                1st Sem, 2nd Year — BS Accountancy
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue-600 mt-1 shrink-0">&#8226;</span>
                1st Sem, 3rd Year — BS Management Accounting
              </li>
            </ul>
          </div>
          <div class="mt-3 pt-3 border-t border-slate-100 text-sm text-slate-600">
            <p class="font-medium text-slate-700 mb-1">Senior High School:</p>
            <p>Calaca Senior High School — ABM Strand</p>
            <ul class="mt-1 space-y-0.5">
              <li class="flex items-start gap-2">
                <span class="text-blue-600 mt-1 shrink-0">&#8226;</span>
                With High Honors — 2021-2022
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue-600 mt-1 shrink-0">&#8226;</span>
                With Honors — 2020-2021
              </li>
            </ul>
          </div>
        </div>
        <!-- Certification -->
        <div class="card">
          <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Certification
          </h2>
          <div>
            <div class="flex-1">
              <h3 class="font-semibold text-slate-900">Certified Bookkeeper</h3>
              <p class="text-sm text-slate-600">AssestPro Training — 2025</p>
              <p class="text-sm text-slate-500 mt-2 leading-relaxed">
                Full-cycle bookkeeping, bank reconciliation, payroll processing,
                financial statement preparation, and internal controls.
              </p>
            </div>
            <a href={imgPath} target="_blank" class="block mt-4 group">
              <img src={imgPath} alt="Certificate" draggable="false" class="w-full max-w-sm rounded-xl border border-slate-200 shadow-sm group-hover:shadow-lg transition-shadow select-none" style="-webkit-user-drag: none; user-select: none;" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Internship Experience -->
  <section id="experience" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    <span class="section-label">Experience</span>
    <h2 class="section-title mb-8">Internship Experience</h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="card">
        <div class="flex flex-wrap justify-between items-start gap-1 mb-3">
          <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide bg-blue-50 px-2.5 py-1 rounded-full">Finance Intern</span>
          <span class="text-xs text-slate-400 shrink-0">[Month Year] - [Month Year]</span>
        </div>
        <h3 class="font-semibold text-slate-900 mb-3">[Company Name]</h3>
        <ul class="space-y-2 text-sm text-slate-600">
          <li class="flex gap-2.5">
            <span class="text-blue-600 font-bold shrink-0 mt-0.5">&rsaquo;</span>
            Accounts payable processing, bank reconciliation, and monthly financial report preparation
          </li>
          <li class="flex gap-2.5">
            <span class="text-blue-600 font-bold shrink-0 mt-0.5">&rsaquo;</span>
            Supported annual budget planning and variance analysis for department heads
          </li>
          <li class="flex gap-2.5">
            <span class="text-blue-600 font-bold shrink-0 mt-0.5">&rsaquo;</span>
            Maintained accurate financial records ensuring compliance with company policies
          </li>
        </ul>
      </div>
      <div class="card">
        <div class="flex flex-wrap justify-between items-start gap-1 mb-3">
          <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide bg-blue-50 px-2.5 py-1 rounded-full">Audit Intern</span>
          <span class="text-xs text-slate-400 shrink-0">[Month Year] - [Month Year]</span>
        </div>
        <h3 class="font-semibold text-slate-900 mb-3">[Company Name]</h3>
        <ul class="space-y-2 text-sm text-slate-600">
          <li class="flex gap-2.5">
            <span class="text-blue-600 font-bold shrink-0 mt-0.5">&rsaquo;</span>
            Participated in external audit engagements including substantive testing and control documentation
          </li>
          <li class="flex gap-2.5">
            <span class="text-blue-600 font-bold shrink-0 mt-0.5">&rsaquo;</span>
            Prepared audit workpapers in accordance with Philippine Standards on Auditing
          </li>
          <li class="flex gap-2.5">
            <span class="text-blue-600 font-bold shrink-0 mt-0.5">&rsaquo;</span>
            Collaborated with senior auditors to identify process improvements
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Skills (Interactive) -->
  <section id="skills" class="bg-white py-10 md:py-16 border-y border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="section-label text-center">Expertise</span>
      <h2 class="section-title mb-10 text-center">Skills & Expertise</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 md:gap-10">

        <!-- Accounting -->
        <div>
          <h3 class="font-semibold text-slate-900 mb-5 text-xs uppercase tracking-[0.12em] text-slate-500 text-center">Accounting</h3>
          <div class="space-y-4">
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Full-Cycle Bookkeeping</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="90"></div>
              </div>
            </div>
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Cost Accounting &amp; Analysis</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="85"></div>
              </div>
            </div>
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Budgeting &amp; Forecasting</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="85"></div>
              </div>
            </div>
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Financial Statement Preparation</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="80"></div>
              </div>
            </div>
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Variance Analysis</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="80"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Tools & Technology -->
        <div>
          <h3 class="font-semibold text-slate-900 mb-5 text-xs uppercase tracking-[0.12em] text-slate-500 text-center">Tools & Technology</h3>
          <div class="space-y-4">
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Microsoft Office Suite</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="95"></div>
              </div>
            </div>
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">BIR Forms &amp; Tax Compliance</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="85"></div>
              </div>
            </div>
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Google Workspace</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="90"></div>
              </div>
            </div>
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">QuickBooks</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="75"></div>
              </div>
            </div>
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Online Banking Platforms</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="80"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Professional -->
        <div>
          <h3 class="font-semibold text-slate-900 mb-5 text-xs uppercase tracking-[0.12em] text-slate-500 text-center">Professional</h3>
          <div class="space-y-4">
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Analytical &amp; Critical Thinking</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="90"></div>
              </div>
            </div>
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Attention to Detail</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="95"></div>
              </div>
            </div>
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Team Collaboration</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="85"></div>
              </div>
            </div>
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Client Communication</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="80"></div>
              </div>
            </div>
            <div class="skill-item">
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-slate-700">Time Management</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-slate-700 rounded-full skill-bar" style="width: 0%" data-width="90"></div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <style>
    .skill-bar {
      transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .skill-bar.animate {
      width: var(--target-width) !important;
    }
    .skill-item:hover .skill-bar {
      background-color: #1e40af;
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const bars = document.querySelectorAll('.skill-bar');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const bar = entry.target;
            bar.style.setProperty('--target-width', bar.dataset.width + '%');
            bar.classList.add('animate');
            observer.unobserve(bar);
          }
        });
      }, { threshold: 0.3 });
      bars.forEach(bar => observer.observe(bar));
    });
  </script>

  <!-- Projects Preview -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    <div class="flex items-center justify-between mb-8">
      <div>
        <span class="section-label">Portfolio</span>
        <h2 class="section-title">Academic Projects</h2>
      </div>
      <a href={basePath + '/case-studies'} class="text-sm text-blue-600 hover:text-blue-700 font-medium flex items-center gap-1">
        View all
        <span class="text-lg leading-none">&rarr;</span>
      </a>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="card-compact">
        <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide bg-blue-50 px-2 py-1 rounded-full">Thesis</span>
        <h3 class="font-semibold text-slate-900 mt-3 mb-1">Cost Behavior Analysis</h3>
        <p class="text-sm text-slate-600 leading-relaxed">ABC analysis for a service company. Identified 3 major cost drivers representing 70% of overhead.</p>
      </div>
      <div class="card-compact">
        <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide bg-blue-50 px-2 py-1 rounded-full">Case Competition</span>
        <h3 class="font-semibold text-slate-900 mt-3 mb-1">Budgeting Simulation</h3>
        <p class="text-sm text-slate-600 leading-relaxed">2nd place among 12 teams. Developed master budget and cash flow forecast.</p>
      </div>
      <div class="card-compact">
        <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide bg-blue-50 px-2 py-1 rounded-full">Dashboard</span>
        <h3 class="font-semibold text-slate-900 mt-3 mb-1">KPI Dashboard</h3>
        <p class="text-sm text-slate-600 leading-relaxed">Power BI dashboard tracking 15+ KPIs for retail business performance.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-blue-600 py-10 md:py-14">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-xl md:text-3xl font-bold text-white mb-3">Let's Connect</h2>
      <p class="text-blue-100/90 text-sm sm:text-base md:text-lg mb-6 md:mb-8">Actively seeking entry-level management accounting opportunities.</p>
      <a href={basePath + '/contact'} class="inline-flex items-center gap-2 px-6 md:px-8 py-3 md:py-3.5 bg-white text-blue-600 font-semibold rounded-lg hover:bg-blue-50 transition-colors shadow-md text-sm md:text-base">
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
