---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base.slice(0, -1) : base;
const imgPath = base.endsWith('/') ? base + 'bk.jpg' : base + '/bk.jpg';
const profilePath = base.endsWith('/') ? base + 'profile.jpg' : base + '/profile.jpg';
---

<BaseLayout title="Trixie Anne B. Name - Management Accounting Portfolio" activePage="home">
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-blue-100 via-indigo-50 to-blue-50 pt-16 pb-0 md:pt-28 md:pb-0">
    <!-- Dot grid pattern overlay -->
    <div class="absolute inset-0 opacity-[0.12]" style="background-image: radial-gradient(rgba(59,130,246,0.4) 1px, transparent 1px); background-size: 24px 24px;"></div>

    <!-- Decorative floating elements -->
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-blue-200/40 blur-3xl float-slow"></div>
    <div class="absolute -bottom-32 -left-32 w-80 h-80 rounded-full bg-indigo-200/30 blur-3xl float-slower"></div>
    <div class="absolute top-1/3 right-1/4 w-48 h-48 rounded-full bg-purple-100/30 blur-2xl float-slow" style="animation-delay: -3s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-gradient-to-br from-blue-100/60 to-transparent blur-2xl"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="flex flex-col md:flex-row items-center md:items-start gap-6 md:gap-10 mb-6 md:mb-8">
          <div class="shrink-0">
            <div class="relative">
              <!-- Animated pulse ring -->
              <div class="absolute inset-0 rounded-full bg-blue-400/20 blur-sm pulse-ring"></div>
              <!-- Glow layers -->
              <div class="absolute inset-0 rounded-full bg-blue-200 blur-2xl opacity-60 scale-110"></div>
              <div class="absolute inset-0 rounded-full bg-indigo-100 blur-xl opacity-40 scale-125"></div>
              <img src={profilePath} alt="Trixie Anne B. Name" draggable="false" class="relative w-28 h-28 md:w-40 md:h-40 rounded-full object-cover ring-4 ring-white shadow-lg select-none" style="-webkit-user-drag: none; user-select: none;" />
            </div>
          </div>
          <div class="text-center md:text-left">
            <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 leading-tight tracking-tight">
              Trixie Anne B. Name
            </h1>
            <p class="text-sm sm:text-base md:text-lg text-blue-700 font-semibold mt-2">
              Management Accountancy Professional
            </p>
            <!-- Open to Work badge -->
            <div class="flex justify-center md:justify-start mt-3">
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-green-50 border border-green-200/60 rounded-full text-xs font-medium text-green-700 shadow-sm">
                <span class="relative flex w-1.5 h-1.5">
                  <span class="absolute inset-0 rounded-full bg-green-500 animate-ping opacity-75"></span>
                  <span class="relative rounded-full bg-green-500 w-1.5 h-1.5"></span>
                </span>
                Open to Work
              </span>
            </div>
          </div>
        </div>
        <p class="text-sm sm:text-base md:text-lg text-slate-600 leading-relaxed max-w-2xl mx-auto md:mx-0">
          Management Accountancy professional with a strong academic foundation in financial management,
          bookkeeping and analytical reporting. Eager to apply and contribute accounting knowledge
          in an internship role by integrating academic learning with hands-on experience.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 mt-6 md:mt-8 justify-center md:justify-start">
          <a href={basePath + '/about'} draggable="false" class="btn-primary shadow-md hover:shadow-lg">
            View My Resume
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
          <a href={basePath + '/contact'} draggable="false" class="btn-secondary">
            Contact Me
          </a>
        </div>
      </div>
    </div>

    <!-- Wave divider -->
    <div class="w-full overflow-hidden leading-[0]">
      <svg viewBox="0 0 1440 56" fill="none" preserveAspectRatio="none" class="w-full h-auto">
        <path d="M0 38C160 14 320 6 480 12C640 18 800 38 960 42C1120 46 1280 34 1440 24V56H0V38Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- Education + Certification Row -->
  <section class="bg-white py-10 md:py-16 border-y border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Education Timeline -->
        <div class="reveal">
          <h2 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
            Education
          </h2>

          <div class="space-y-5">
            <!-- BSMA -->
            <div class="flex gap-4">
              <div class="flex flex-col items-center">
                <div class="w-3.5 h-3.5 rounded-full bg-blue-600 ring-[5px] ring-white shrink-0 mt-1"></div>
                <div class="w-0.5 flex-1 bg-blue-100"></div>
              </div>
              <div class="flex-1 pb-2">
                <div class="bg-white rounded-xl border border-slate-200 p-4 hover:border-blue-200 hover:shadow-md transition-all duration-200">
                  <h3 class="font-semibold text-slate-900">BS Management Accounting</h3>
                  <p class="text-sm text-slate-600">Batangas State University (TNEU) &mdash; ARASOF Nasugbu Campus</p>
                  <p class="text-sm text-slate-400 mt-1">2022 &ndash; 2026</p>
                  <div class="mt-3 pt-3 border-t border-slate-100 text-sm text-slate-600">
                    <p class="font-medium text-slate-700 mb-1">Dean's List:</p>
                    <ul class="space-y-0.5">
                      <li class="flex items-start gap-2"><span class="text-blue-600 mt-1 shrink-0">&#8226;</span>1st Sem, 1st Year &mdash; BS Accountancy</li>
                      <li class="flex items-start gap-2"><span class="text-blue-600 mt-1 shrink-0">&#8226;</span>1st Sem, 2nd Year &mdash; BS Accountancy</li>
                      <li class="flex items-start gap-2"><span class="text-blue-600 mt-1 shrink-0">&#8226;</span>1st Sem, 3rd Year &mdash; BS Management Accounting</li>
                      <li class="flex items-start gap-2"><span class="text-blue-600 mt-1 shrink-0">&#8226;</span>2nd Sem, 4th Year &mdash; BS Management Accounting</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- SHS -->
            <div class="flex gap-4">
              <div class="flex flex-col items-center">
                <div class="w-3.5 h-3.5 rounded-full bg-blue-600 ring-[5px] ring-white shrink-0 mt-1"></div>
                <div class="w-0.5 flex-1 bg-blue-100"></div>
              </div>
              <div class="flex-1 pb-2">
                <div class="bg-white rounded-xl border border-slate-200 p-4 hover:border-blue-200 hover:shadow-md transition-all duration-200">
                  <h3 class="font-semibold text-slate-900">Accountancy, Business &amp; Management</h3>
                  <p class="text-sm text-slate-600">Calaca Senior High School &mdash; Calaca City, Batangas</p>
                  <p class="text-sm text-slate-400 mt-1">2020 &ndash; 2022</p>
                  <ul class="mt-3 space-y-0.5 text-sm text-slate-600">
                    <li class="flex items-start gap-2"><span class="text-blue-600 mt-1 shrink-0">&#8226;</span>With Honors &mdash; 2020-2021</li>
                    <li class="flex items-start gap-2"><span class="text-blue-600 mt-1 shrink-0">&#8226;</span>With High Honors &mdash; 2021-2022</li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- JHS -->
            <div class="flex gap-4">
              <div class="flex flex-col items-center">
                <div class="w-3.5 h-3.5 rounded-full bg-blue-600 ring-[5px] ring-white shrink-0 mt-1"></div>
                <div class="w-0.5 flex-1 bg-blue-100"></div>
              </div>
              <div class="flex-1 pb-2">
                <div class="bg-white rounded-xl border border-slate-200 p-4 hover:border-blue-200 hover:shadow-md transition-all duration-200">
                  <h3 class="font-semibold text-slate-900">Junior High School</h3>
                  <p class="text-sm text-slate-600">Dacanlao Gregorio Agoncillo National High School &mdash; Calaca City, Batangas</p>
                  <p class="text-sm text-slate-400 mt-1">2016 &ndash; 2020</p>
                  <ul class="mt-3 space-y-0.5 text-sm text-slate-600">
                    <li class="flex items-start gap-2"><span class="text-blue-600 mt-1 shrink-0">&#8226;</span>Consistent With Honors &mdash; 2017-2020</li>
                    <li class="flex items-start gap-2"><span class="text-blue-600 mt-1 shrink-0">&#8226;</span>Member, The Mathematics Association of the Philippines, Inc. (MTAP)</li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Elementary -->
            <div class="flex gap-4">
              <div class="flex flex-col items-center">
                <div class="w-3.5 h-3.5 rounded-full bg-blue-600 ring-[5px] ring-white shrink-0 mt-1"></div>
              </div>
              <div class="flex-1">
                <div class="bg-white rounded-xl border border-slate-200 p-4 hover:border-blue-200 hover:shadow-md transition-all duration-200">
                  <h3 class="font-semibold text-slate-900">Elementary</h3>
                  <p class="text-sm text-slate-600">Calaca Central School &mdash; Calaca City, Batangas</p>
                  <p class="text-sm text-slate-400 mt-1">2010 &ndash; 2016</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Certification & Seminars -->
        <div class="space-y-6">
          <div class="card reveal reveal-delay-1">
            <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Certification
            </h2>
            <div>
              <h3 class="font-semibold text-slate-900">Certified Bookkeeper</h3>
              <p class="text-sm text-slate-600">PICAT (Philippine Institute of Certified Accounting Technologist) &mdash; 2025</p>
              <a href={imgPath} target="_blank" draggable="false" class="block mt-4 group">
                <img src={imgPath} alt="Certificate" draggable="false" class="w-full max-w-sm rounded-xl border border-slate-200 shadow-sm group-hover:shadow-lg transition-shadow select-none" style="-webkit-user-drag: none; user-select: none;" />
              </a>
            </div>
          </div>

          <div class="card reveal reveal-delay-2">
            <h3 class="font-semibold text-slate-900 mb-2">HP LIFE Online Course</h3>
            <p class="text-sm text-slate-600">HP Foundation &mdash; 2022</p>
            <p class="text-sm text-slate-500 mt-1">Cash Flow, Profit and Loss</p>
          </div>

          <div class="card reveal reveal-delay-2">
            <h3 class="font-semibold text-slate-900 mb-2">Seminars &amp; Participations</h3>
            <ul class="space-y-1.5 text-sm text-slate-600">
              <li class="flex items-start gap-2"><span class="text-blue-600 mt-1 shrink-0">&#8226;</span>Pathways to Success: Navigating your Career in Management Accounting (Webinar) &mdash; November 2022</li>
              <li class="flex items-start gap-2"><span class="text-blue-600 mt-1 shrink-0">&#8226;</span>National Federation of Junior Philippine Institute of Accountants &mdash; Member 2023-2024</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Internship Experience -->
  <section id="experience" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    <span class="section-label reveal">Experience</span>
    <h2 class="section-title mb-8 reveal reveal-delay-1">Internship Experience</h2>
    <div class="grid md:grid-cols-1 gap-6">
      <div class="card reveal reveal-delay-2">
        <div class="flex flex-wrap justify-between items-start gap-1 mb-3">
          <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide bg-blue-50 px-2.5 py-1 rounded-full">Human Resource Development Intern</span>
          <span class="text-xs text-slate-400 shrink-0">Aug 20 &ndash; Nov 11, 2025</span>
        </div>
        <h3 class="font-semibold text-slate-900 mb-3">Batangas I Electric Cooperative, Inc. (BATELEC I)</h3>
        <ul class="space-y-2 text-sm text-slate-600">
          <li class="flex gap-2.5">
            <span class="text-blue-600 font-bold shrink-0 mt-0.5">&rsaquo;</span>
            Assisted in payroll operations, including encoding labor costing, checking employees&rsquo; daily reports, and distributing pay slips.
          </li>
          <li class="flex gap-2.5">
            <span class="text-blue-600 font-bold shrink-0 mt-0.5">&rsaquo;</span>
            Organized and filed personnel documents while ensuring confidentiality of employee information.
          </li>
          <li class="flex gap-2.5">
            <span class="text-blue-600 font-bold shrink-0 mt-0.5">&rsaquo;</span>
            Assisted in organizing training programs and employee engagement activities.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills" class="bg-slate-50/60 py-10 md:py-16 border-y border-slate-200/70">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="section-label text-center reveal">Skills</span>
      <h2 class="section-title mb-10 text-center reveal reveal-delay-1">Skills &amp; Expertise</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-6 max-w-3xl mx-auto">

        <div class="bg-white rounded-xl border border-slate-200/70 p-5 reveal reveal-delay-1">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="font-semibold text-slate-800 text-sm">Tools &amp; Software</h3>
          </div>
          <p class="text-sm text-slate-600 leading-relaxed">Proficient in using Microsoft Office (Word, Excel, PowerPoint) and Canva.</p>
        </div>

        <div class="bg-white rounded-xl border border-slate-200/70 p-5 reveal reveal-delay-2">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h3 class="font-semibold text-slate-800 text-sm">Work Style</h3>
          </div>
          <p class="text-sm text-slate-600 leading-relaxed">Ability to work effectively both independently and in a team environment.</p>
        </div>

        <div class="bg-white rounded-xl border border-slate-200/70 p-5 reveal reveal-delay-3">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            </div>
            <h3 class="font-semibold text-slate-800 text-sm">Communication</h3>
          </div>
          <p class="text-sm text-slate-600 leading-relaxed">Strong communication and interpersonal skills.</p>
        </div>

        <div class="bg-white rounded-xl border border-slate-200/70 p-5 reveal reveal-delay-4">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="font-semibold text-slate-800 text-sm">Time Management</h3>
          </div>
          <p class="text-sm text-slate-600 leading-relaxed">Excellent in time management.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Projects Preview -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    <div class="flex items-center justify-between mb-8 reveal">
      <div>
        <span class="section-label">Portfolio</span>
        <h2 class="section-title">Academic Projects</h2>
      </div>
      <a href={basePath + '/case-studies'} class="text-sm text-blue-600 hover:text-blue-700 font-medium flex items-center gap-1">
        View all
        <span class="text-lg leading-none">&rarr;</span>
      </a>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="card-compact reveal reveal-delay-1 relative overflow-hidden hover:shadow-md transition-all duration-300">
        <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-blue-400 to-blue-600"></div>
        <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide bg-blue-50 px-2 py-1 rounded-full">Thesis</span>
        <h3 class="font-semibold text-slate-900 mt-3 mb-1">Cost Behavior Analysis</h3>
        <p class="text-sm text-slate-600 leading-relaxed">ABC analysis for a service company. Identified 3 major cost drivers representing 70% of overhead.</p>
      </div>
      <div class="card-compact reveal reveal-delay-2 relative overflow-hidden hover:shadow-md transition-all duration-300">
        <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-indigo-400 to-indigo-600"></div>
        <span class="text-xs font-semibold text-indigo-600 uppercase tracking-wide bg-indigo-50 px-2 py-1 rounded-full">Case Competition</span>
        <h3 class="font-semibold text-slate-900 mt-3 mb-1">Budgeting Simulation</h3>
        <p class="text-sm text-slate-600 leading-relaxed">2nd place among 12 teams. Developed master budget and cash flow forecast.</p>
      </div>
      <div class="card-compact reveal reveal-delay-3 relative overflow-hidden hover:shadow-md transition-all duration-300">
        <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-emerald-400 to-emerald-600"></div>
        <span class="text-xs font-semibold text-emerald-600 uppercase tracking-wide bg-emerald-50 px-2 py-1 rounded-full">Dashboard</span>
        <h3 class="font-semibold text-slate-900 mt-3 mb-1">KPI Dashboard</h3>
        <p class="text-sm text-slate-600 leading-relaxed">Power BI dashboard tracking 15+ KPIs for retail business performance.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-blue-600 py-10 md:py-14">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-xl md:text-3xl font-bold text-white mb-3">Let's Connect</h2>
      <p class="text-blue-100/90 text-sm sm:text-base md:text-lg mb-6 md:mb-8">Actively seeking entry-level management accounting opportunities.</p>
      <a href={basePath + '/contact'} draggable="false" class="inline-flex items-center gap-2 px-6 md:px-8 py-3 md:py-3.5 bg-white text-blue-600 font-semibold rounded-lg hover:bg-blue-50 transition-colors shadow-md text-sm md:text-base">
        Get in Touch
      </a>
    </div>
  </section>

  <style>
    /* Reveal animations */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }

    /* Hero animations */
    @keyframes pulse-ring {
      0% { transform: scale(1); opacity: 0.5; }
      50% { transform: scale(1.12); opacity: 0.15; }
      100% { transform: scale(1); opacity: 0.5; }
    }
    .pulse-ring {
      animation: pulse-ring 3s ease-in-out infinite;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-12px); }
    }
    .float-slow {
      animation: float 8s ease-in-out infinite;
    }
    .float-slower {
      animation: float 12s ease-in-out infinite;
    }

  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Reveal observer for sections/cards
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
    });
  </script>
</BaseLayout>
